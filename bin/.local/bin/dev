#!/usr/bin/env bash
set -euo pipefail

SITES_DIR="$HOME/dev/caddy-sites"
CADDYFILE="/opt/homebrew/etc/Caddyfile"

PROJECT_DIR=""
REPO_NAME=""
DOMAIN=""
SNIPPET=""
CONFIG_FILE=""
WEB_ROOT=""
PORT=""
CONFIG_PORT=""
PHP_LOG_FILE=""
PHP_PID_FILE=""
declare -a ALIASES=()

usage() {
  echo "Uso:"
  echo "  dev up [nombre_carpeta]"
  echo "  dev down [nombre_carpeta]"
  echo "  dev status [nombre_carpeta]"
  echo "  dev down-all"
  exit 1
}

cmd="${1:-}"
name="${2:-}"

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

port_is_listening() {
  local p="$1"
  lsof -nP -iTCP:"$p" -sTCP:LISTEN >/dev/null 2>&1
}

wait_for_port() {
  local p="$1"
  local timeout_sec="${2:-8}"
  local elapsed=0

  while (( elapsed < timeout_sec * 10 )); do
    if port_is_listening "$p"; then
      return 0
    fi
    sleep 0.1
    elapsed=$((elapsed + 1))
  done

  return 1
}

resolve_project() {
  local target_dir=""

  if [[ -n "$name" ]]; then
    if [[ -d "$HOME/dev/www/$name" ]]; then
      target_dir="$HOME/dev/www/$name"
    elif [[ -d "$name" ]]; then
      target_dir="$(cd "$name" && pwd)"
    else
      echo "Error: no existe el proyecto '$name'" >&2
      exit 1
    fi
  else
    target_dir="$PWD"
  fi

  if git -C "$target_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    local repo_root
    local git_common

    repo_root="$(git -C "$target_dir" rev-parse --show-toplevel)"
    git_common="$(git -C "$target_dir" rev-parse --git-common-dir)"

    if [[ "$git_common" != /* ]]; then
      git_common="$(cd "$repo_root" && cd "$git_common" && pwd)"
    else
      git_common="$(cd "$git_common" && pwd)"
    fi

    PROJECT_DIR="$repo_root"
    REPO_NAME="$(basename "$(dirname "$git_common")")"
  else
    PROJECT_DIR="$target_dir"
    REPO_NAME="$(basename "$target_dir")"
  fi

  DOMAIN="${REPO_NAME}.test"
  SNIPPET="$SITES_DIR/${REPO_NAME}.caddy"
  CONFIG_FILE="$PROJECT_DIR/.config/caddy"
  WEB_ROOT="$PROJECT_DIR"
  PHP_LOG_FILE="/tmp/dev-${REPO_NAME}.log"
  PHP_PID_FILE="/tmp/dev-${REPO_NAME}.pid"

  if [[ -d "$PROJECT_DIR/public" ]]; then
    WEB_ROOT="$PROJECT_DIR/public"
  fi
}

append_alias_if_missing() {
  local candidate="$1"
  local existing

  [[ -n "$candidate" ]] || return 0

  for existing in "${ALIASES[@]-}"; do
    if [[ "$existing" == "$candidate" ]]; then
      return 0
    fi
  done

  ALIASES+=("$candidate")
}

normalize_alias_host() {
  local host="$1"

  host="$(trim "$host")"
  [[ -n "$host" ]] || return 0

  case "$host" in
    *.test) printf '%s\n' "$host" ;;
    *) printf '%s.test\n' "$host" ;;
  esac
}

load_alias_values() {
  local value="$1"
  local token

  value="$(trim "$value")"

  case "$value" in
    '"'*) value="${value#\"}"; value="${value%\"}" ;;
    "'"*) value="${value#\'}"; value="${value%\'}" ;;
  esac

  value="${value//,/ }"
  for token in $value; do
    append_alias_if_missing "$(normalize_alias_host "$token")"
  done
}

load_project_config() {
  CONFIG_PORT=""
  ALIASES=()

  [[ -f "$CONFIG_FILE" ]] || return 0

  while IFS= read -r raw; do
    local line
    local value

    line="$(trim "${raw%%#*}")"
    [[ -z "$line" ]] && continue

    case "$line" in
      [Pp][Oo][Rr][Tt]=*)
        value="$(trim "${line#*=}")"
        case "$value" in
          '"'*) value="${value#\"}"; value="${value%\"}" ;;
          "'"*) value="${value#\'}"; value="${value%\'}" ;;
        esac
        CONFIG_PORT="$value"
        ;;
      [Aa][Ll][Ii][Aa][Ss][Ee][Ss]=*)
        value="${line#*=}"
        load_alias_values "$value"
        ;;
    esac
  done < "$CONFIG_FILE"
}

pick_port() {
  if [[ -z "$CONFIG_PORT" ]]; then
    echo "Error: falta PORT en $CONFIG_FILE" >&2
    exit 1
  fi

  if [[ ! "$CONFIG_PORT" =~ ^[0-9]+$ ]]; then
    echo "Error: PORT inválido en $CONFIG_FILE" >&2
    exit 1
  fi

  PORT="$CONFIG_PORT"
}

write_snippet() {
  mkdir -p "$SITES_DIR"

  local hosts=("${DOMAIN}")
  local h

  for h in "${ALIASES[@]-}"; do
    [[ -z "$h" ]] && continue
    hosts+=("$h")
  done

  # Une hosts con espacios (site labels múltiples)
  local host_line
  host_line="$(printf "%s " "${hosts[@]}")"
  host_line="${host_line% }"

  cat > "$SNIPPET" <<SNIP
${host_line} {
  tls internal
reverse_proxy 127.0.0.1:${PORT} {
  header_up Host {host}
  header_up X-Forwarded-Proto https
}
}
SNIP
}

reload_caddy() {
  local start_if_needed="${1:-no}"

  run_caddy() {
    local subcmd="$1"
    shift

    if caddy "$subcmd" "$@" >/dev/null 2>&1; then
      return 0
    fi

    if sudo -n caddy "$subcmd" "$@" >/dev/null 2>&1; then
      return 0
    fi

    echo "Error: no pude ejecutar 'caddy $subcmd' sin interacción." >&2
    echo "Ejecuta 'sudo -v' una vez y vuelve a lanzar 'dev up'." >&2
    return 1
  }

  if ! curl -fsS http://localhost:2019/config/ >/dev/null 2>&1; then
    if [[ "$start_if_needed" == "yes" ]]; then
      run_caddy start --config "$CADDYFILE" --adapter caddyfile
    else
      return 0
    fi
  fi

  run_caddy reload --config "$CADDYFILE" --adapter caddyfile
}

start_php_server() {
  mkdir -p "$(dirname "$PHP_LOG_FILE")"
  : > "$PHP_LOG_FILE"

  mkdir -p "$(dirname "$PHP_PID_FILE")"

  (
    cd "$PROJECT_DIR"
    nohup php -S "127.0.0.1:${PORT}" -t "$WEB_ROOT" >"$PHP_LOG_FILE" 2>&1 < /dev/null &
    printf '%s\n' "$!" > "$PHP_PID_FILE"
  )
}

show_php_log() {
  if [[ -f "$PHP_LOG_FILE" ]]; then
    tail -n 40 "$PHP_LOG_FILE" >&2 || true
  else
    echo "Log no encontrado: $PHP_LOG_FILE" >&2
  fi
}

read_php_pid() {
  local pid=""

  [[ -f "$PHP_PID_FILE" ]] || return 1
  pid="$(trim "$(<"$PHP_PID_FILE")")"
  [[ -n "$pid" && "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$pid"
}

php_pid_is_running() {
  local pid="$1"

  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" >/dev/null 2>&1
}

stop_php_server() {
  local pid=""

  if pid="$(read_php_pid 2>/dev/null)"; then
    if php_pid_is_running "$pid"; then
      kill "$pid" >/dev/null 2>&1 || true
      sleep 0.2
      if php_pid_is_running "$pid"; then
        kill -9 "$pid" >/dev/null 2>&1 || true
      fi
    fi
    rm -f "$PHP_PID_FILE"
    return 0
  fi

  return 1
}

case "${cmd}" in
  up)
    resolve_project
    load_project_config

    stop_php_server || true

    pick_port

    if port_is_listening "$PORT"; then
      echo "Error: puerto $PORT ocupado para ${DOMAIN}." >&2
      echo "Sugerencia: revisa el proceso con 'lsof -nP -iTCP:$PORT -sTCP:LISTEN'" >&2
      exit 1
    fi

    if [[ ! -f "$SNIPPET" ]]; then
      write_snippet
      reload_caddy yes
    fi

    start_php_server
    if ! wait_for_port "$PORT" 10; then
      echo "Error: PHP no quedó escuchando en el puerto $PORT para ${DOMAIN}." >&2
      show_php_log
      exit 1
    fi

    echo "OK: https://${DOMAIN}  ->  127.0.0.1:${PORT} (${PROJECT_DIR})"
    echo "Log: $PHP_LOG_FILE"
    ;;

  down)
    resolve_project

    stop_php_server || true
    echo "OK: parado ${DOMAIN}"
    ;;

  status)
    resolve_project
    load_project_config

    echo "Proyecto: $REPO_NAME"
    echo "Ruta actual: $PROJECT_DIR"
    echo "Dominio: $DOMAIN"
    if [[ -f "$CONFIG_FILE" ]]; then
      echo "Config: $CONFIG_FILE"
    else
      echo "Config: (sin .config/caddy)"
    fi

    if [[ -n "$CONFIG_PORT" ]]; then
      PORT="$CONFIG_PORT"
      echo "Puerto fijo (config): $CONFIG_PORT"
    else
      PORT=""
      echo "Puerto: (sin asignar)"
    fi

    if pid="$(read_php_pid 2>/dev/null)" && php_pid_is_running "$pid"; then
      echo "Servidor PHP: activo en 127.0.0.1:$PORT"
      echo "Log: $PHP_LOG_FILE"
    else
      echo "Servidor PHP: inactivo"
      echo "Log: $PHP_LOG_FILE"
    fi

    show_php_log
    ;;

  down-all)
    echo "Parando todos los proyectos..."

    for pidfile in /tmp/dev-*.pid; do
      [[ -f "$pidfile" ]] || continue
      PHP_PID_FILE="$pidfile"
      stop_php_server
    done

    echo "OK: todos los servidores PHP detenidos"
    ;;

  *)
    usage
    ;;
esac
