#!/usr/bin/env bash

set -euo pipefail

project="$(
  zoxide query -l \
    | awk '!seen[$0]++' \
    | fzf \
        --height=100% \
        --layout=reverse \
        --border=none \
        --prompt='project > ' \
        --preview='' \
        --preview-window=hidden
)" || exit 0

[ -n "${project:-}" ] || exit 0

get_worktrees() {
  git -C "$1" worktree list --porcelain 2>/dev/null \
    | awk '
        /^worktree / {
          print substr($0, 10)
        }
      '
}

get_extra_worktrees() {
  local root="$1"
  get_worktrees "$root" | awk -v root="$root" '$0 != root'
}

is_git_repo() {
  git -C "$1" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

worktrees=""

if is_git_repo "$project"; then
  worktrees="$(get_extra_worktrees "$project" || true)"
fi

if [ -n "${worktrees:-}" ]; then
  dir="$(
    printf '%s\n' "$worktrees" \
      | awk -F/ '
          {
            n = split($0, parts, "/")
            print parts[n] "\t" $0
          }
        ' \
      | fzf \
          --height=100% \
          --layout=reverse \
          --border=none \
          --prompt='worktree > ' \
          --delimiter=$'\t' \
          --with-nth=1 \
          --preview='' \
          --preview-window=hidden
  )" || exit 0

  [ -n "${dir:-}" ] || exit 0
  dir="$(printf '%s\n' "$dir" | cut -f2)"
else
  dir="$project"
fi

session_name="$(
  printf '%s\n' "$dir" \
    | awk -F/ '
        {
          n = split($0, parts, "/")

          start = 0
          for (i = 1; i <= n; i++) {
            if (parts[i] == "dev") {
              start = i + 1
              break
            }
          }

          if (start == 0 || start > n) {
            for (i = n; i >= 1; i--) {
              if (parts[i] != "") {
                print parts[i]
                exit
              }
            }
            exit 1
          }

          if (parts[start] == "www") {
            start++
          }

          if (start > n) {
            for (i = n; i >= 1; i--) {
              if (parts[i] != "") {
                print parts[i]
                exit
              }
            }
            exit 1
          }

          project = parts[start]

          sub(/\.[^.]+$/, "", project)

          if ((start + 2) <= n && parts[start + 1] == ".worktrees") {
            branch = parts[start + 2]
            print project "_" branch
          } else {
            print project
          }
        }
      ' \
    | tr ".:/" "_" \
    | tr -s "_"
)"

if [ -n "${TMUX:-}" ]; then
  if tmux has-session -t="$session_name" 2>/dev/null; then
    tmux switch-client -t "$session_name"
  else
    tmux new-session -d -s "$session_name" -c "$dir"
    tmux switch-client -t "$session_name"
  fi
else
  exec tmux new-session -A -s "$session_name" -c "$dir"
fi
