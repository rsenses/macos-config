{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "share": "manual",
  "agent": {
    "build": {
      "model": "openai/gpt-5.4-fast",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "model": "openrouter/moonshotai/kimi-k2:free",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    }
  },
  "mcp": {
    "laravel-boost": {
      "type": "local",
      "command": ["php", "artisan", "boost:mcp"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--slim",
        "--headless"
      ],
      "enabled": true
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "git push": "ask",
      "git status": "allow",
      "git diff": "allow",
      "npm run build": "allow",
      "ls": "allow",
      "pwd": "allow",
      "cd": "allow",
      "grep": "allow",
      "find": "allow",
      "sed": "allow"
    },
    "webfetch": "ask"
  }
}
