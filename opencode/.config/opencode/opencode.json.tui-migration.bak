{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "instructions": ["AGENTS.md"],
  "share": "manual",
  "mcp": {
    "laravel-boost": {
      "type": "local",
      "command": ["php", "artisan", "boost:mcp"],
      "enabled": true
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "git push": "ask",
      "git status": "allow",
      "git diff": "allow",
      "npm run build": "allow",
      "ls": "allow",
      "pwd": "allow",
      "cd": "allow",
      "grep": "allow",
      "find": "allow",
      "sed": "allow"
    },
    "webfetch": "ask"
  }
}
