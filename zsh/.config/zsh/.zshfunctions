# destinations, my file organization
destinations() {
  local base="$HOME/data"
  local root

  for root in "$base/work" "$base/personal"; do
    [[ -d "$root" ]] || continue

    # 🔹 destinos base (rápidos)
    [[ -d "$root/inbox" ]] && printf '%s\n' "$root/inbox"
    [[ -d "$root/media" ]] && printf '%s\n' "$root/media"
    [[ -d "$root/notes" ]] && printf '%s\n' "$root/notes"

    # 🔹 docs/topics (niveles semánticos)
    if [[ -d "$root/docs/topics" ]]; then
      find "$root/docs/topics" -mindepth 1 -maxdepth 2 -type d
    fi

    # 🔹 clients → solo destinos útiles (no raíz cliente)
    if [[ -d "$root/docs/clients" ]]; then
      find "$root/docs/clients" -mindepth 2 -maxdepth 3 -type d
    fi

    # 🔹 proyectos personales
    if [[ -d "$root/projects" ]]; then
      find "$root/projects" -mindepth 1 -maxdepth 2 -type d
    fi

  done | sort -u
}


# select destination
dest() {
  destinations | sed "s|^$HOME/|~/|" | fzf --prompt="Destino> "
}

# send downloaded files on destination
send_downloads() {
  local downloads="$HOME/Downloads"
  local src src_abs dst

  [[ -d "$downloads" ]] || return 1

  while :; do
    src="$(
      find "$downloads" -mindepth 1 -maxdepth 1 ! -name '.DS_Store' \
      | sed "s|^$HOME/|~/|" \
      | fzf \
        --prompt="Downloads> " \
        --header="ENTER mover | CTRL-D trash | CTRL-O quicklook | CTRL-R rename | ESC salir" \
        --preview '
          p="${1/#\~/'"$HOME"'}"
          if [ -d "$p" ]; then
            eza -la --group-directories-first --color=always "$p" 2>/dev/null ||
            ls -la "$p"
          elif file --mime "$p" | grep -q "charset=binary"; then
            file "$p"
          else
            bat --style=numbers --color=always "$p" 2>/dev/null ||
            file "$p"
          fi
        ' \
        --bind "ctrl-d:execute-silent(
          printf '%s\n' {} | sed 's|^~|$HOME|' | xargs -I {} trash \"{}\"
        )+reload(
          find $downloads -mindepth 1 -maxdepth 1 ! -name '.DS_Store' | sed 's|^$HOME/|~/|'
        )" \
        --bind "ctrl-o:execute-silent(
          p=\$(printf '%s\n' {} | sed 's|^~|$HOME|');
          qlmanage -p \"\$p\" >/dev/null 2>&1 &
        )" \
        --bind "ctrl-r:execute(
          p=\$(printf '%s\n' {} | sed 's|^~|$HOME|');
          dir=\$(dirname \"\$p\");
          base=\$(basename \"\$p\");
          printf 'Rename %s -> ' \"\$base\" > /dev/tty;
          read -r newname < /dev/tty;
          if [ -n \"\$newname\" ] && [ \"\$newname\" != \"\$base\" ]; then
            mv \"\$p\" \"\$dir/\$newname\";
          fi
        )+reload(
          find $downloads -mindepth 1 -maxdepth 1 ! -name '.DS_Store' | sed 's|^$HOME/|~/|'
        )"
    )" || break

    [[ -z "$src" ]] && break
    src_abs="${src/#\~/$HOME}"

    dst="$(dest)" || continue
    [[ -n "$dst" ]] || continue
    dst="${dst/#\~/$HOME}"

    mv "$src_abs" "$dst"
  done
}

# ssh
ss() {
  local ssh_config="$HOME/.ssh/config"
  [[ -f "$ssh_config" ]] || { printf 'ss: no encuentro %s\n' "$ssh_config" >&2; return 1; }
  command -v fzf >/dev/null 2>&1 || { printf 'ss: fzf no está instalado\n' >&2; return 1; }

  local server
  server=$(
    awk '
      /^Host[[:space:]]+/ {
        for (i = 2; i <= NF; i++) print $i
      }
    ' "$ssh_config" \
      | grep -vE '(^\*|!|[*?])' \
      | sort -u \
      | fzf --prompt="ssh > " --preview ':' --preview-window hidden
  ) || return

  [[ -n "$server" ]] && ssh "$server"
}

# select notes dir and open in nvim
notes() {
  local type
  type=$(printf "work\npersonal" | fzf) || return
  nvim "$HOME/data/$type/notes/daily.md"
}

# show last downloaded file
lastdl() {
  echo "$HOME/Downloads/$(ls -t ~/Downloads | head -n 1)"
}

# cambiar de rama con preview
gbr() {
  local branch
  branch=$(
    git branch --all --sort=-committerdate \
      | sed 's/^[* ]*//' \
      | sed 's#remotes/origin/##' \
      | sort -u \
      | fzf --prompt='branch > ' \
          --preview 'git log --oneline --decorate --graph -20 {}'
  ) || return

  git switch "$branch"
}

# git add con fzf
gaf() {
  local files
  files=("${(@f)$(git status --short | sed 's/^...//' | fzf -m)}") || return
  [[ ${#files[@]} -gt 0 ]] && git add -- "${files[@]}"
}

# git conflicts con fzf y abre en nvim
gcf() {
  local file

  file=$(
    git diff --name-only --diff-filter=U \
      | fzf --prompt='conflict > '
  ) || return

  nvim "$file"
}

# git resuelve conflictos todos con ours
gours() {
  git diff --name-only --diff-filter=U | while read -r f; do
    git checkout --ours -- "$f"
  done
  git add .
}

# resize images
resize() {
    if [[ $# -lt 3 ]]; then
        echo "Uso: resize <imagen> <ancho_resize_px> <tamaño_final (ej. 250x250 o 250x300)> [color_fondo] (en hexadecimal o none para transparente, por defecto blanco)"
        echo "Ejemplo: resize logo.png 200 250x250 white"
        return 1
    fi

    local input="$1"
    local resize_width="$2"
    local final_size="$3"
    local bg="${4:-white}"  # fondo blanco por defecto

    # Obtener nombre base y extensión
    local base="${input%.*}"
    local ext="${input##*.}"

    # Generar nombre de salida: nombre-<resize>-<final>.ext
    local output="${base}-${resize_width}.${ext}"

    magick "$input" \
      -filter Lanczos \
      -resize "${resize_width}x" \
      -background "$bg" \
      -gravity center \
      -extent "$final_size" \
      "$output"

    echo "✅ Imagen generada: $output"
}

mkcd() { mkdir -p "$1" && cd "$1"; }

_fzf_home_dirs() {
  fd -H -t d . "$HOME" \
    -d 3 \
    -E .git \
    -E node_modules \
    -E vendor \
    -E .cache \
    -E .Trash \
    -E Library \
    -E .next \
    -E dist \
    -E build \
    -E target \
    -E coverage \
    -E .turbo \
    -E .vscode \
    -E .idea
}

pickdir() {
  _fzf_home_dirs | fzf --prompt='destino > ' --delimiter="$HOME/" --with-nth=2
}

mvv() {
  local src="$1"
  local dst

  [[ -z "$src" ]] && { echo "uso: mvv <archivo>"; return 1; }

  dst=$(pickdir) || return
  mv -- "$src" "$dst/"
}

cpp() {
  local src="$1"
  local dst

  [[ -z "$src" ]] && { echo "uso: cpp <archivo>"; return 1; }

  dst=$(pickdir) || return
  cp -- "$src" "$dst/"
}
