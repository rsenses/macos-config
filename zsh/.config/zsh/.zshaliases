# Bookmarks
alias help='tldr --list | fzf --preview "tldr {1}" --preview-window=right,70% | xargs tldr'

# Colorize grep output (good for log files)
alias grep='grep --color=auto'

# confirm before overwriting something
alias cp="cp -i"
alias mv='mv -i'
alias o='open .'
unalias rm 2>/dev/null
rm() {
  # bloquear uso peligroso
  if [[ "$*" == *"-rf"* ]] || [[ "$*" == *"-fr"* ]]; then
    echo "⚠️  Bloqueado: usa 'command rm -rf ...' si estás seguro"
    return 1
  fi

  # si el usuario quiere confirmación explícita
  if [[ "$*" == *"-i"* ]]; then
    command rm "$@"
    return
  fi

  # comportamiento por defecto → papelera
  trash "$@"
}

# i can't remove vim in mac
alias vim='nvim'

# Recursively delete `.DS_Store` files
alias dsstore="find . -name '*.DS_Store' -type f -ls -delete"

# Update installed Homebrew, npm, composer and zsh
alias brew-update="brew -v update; brew upgrade; brew cleanup; brew doctor"
alias composer-update='composer self-update && composer global update'
alias npm-update='npm update -g; npm cache clean --force'
alias update="brew-update; composer-update; npm-update"

# ImageOptim, se puede usar . o nombre de archivo
alias imageoptim="open -a ImageOptim"

# less con color
alias less='less -R'

# executables
alias ls='ls --color=auto'
alias lt='ls -lAFtr'
alias ll='ls -lAFr'
alias lsize='ls -lhSF'

#weather
alias weather='curl "wttr.in/Leganes?T&lang=es"'

# tmux
alias ta='tmux attach -t'

# git
unalias git 2>/dev/null

git() {
  case "$1" in
    s|status)
      echo "[hint] usa: gs  → git status -sb" >&2
      ;;
    diff)
      echo "[hint] usa: gd  → git diff" >&2
      ;;
    log)
      echo "[hint] usa: glg  → git log" >&2
      ;;
    add)
      if [[ "$2" == "." ]]; then
        echo "[hint] usa: gaa → git add ." >&2
      else
        echo "[hint] usa: ga ... → git add ..." >&2
      fi
      ;;
    commit)
      if [[ "$*" == *"--amend"* ]]; then
        echo "[hint] usa: gca → git commit --amend" >&2
      elif [[ "$*" == *"-m"* ]]; then
        echo '[hint] usa: gcm "mensaje" → git commit -m "mensaje"' >&2
      else
        echo "[hint] usa: gc → git commit" >&2
      fi
      ;;
    push)
      echo "[hint] usa: gp  → git push" >&2
      ;;
    pull)
      echo "[hint] usa: gl  → git pull" >&2
      ;;
    branch)
      echo "[hint] usa: gb  → git branch" >&2
      ;;
    checkout)
      echo "[hint] usa: gco ... → git checkout ..." >&2
      ;;
    "")
      echo "[hint] aliases: gs gd ga gaa gc gcm gca gp gl gb gco" >&2
      ;;
  esac

  command git "$@"
}

alias g='command git'
alias gs='command git status -sb'
alias gd='command git diff'
alias glg='command git lg'
alias ga='command git add'
alias gaa='command git add .'
alias gai='command git add -i'
alias gap='command git add -p'
alias gc='command git commit'
alias gca='command git commit --amend --reuse-message=HEAD'
alias gp='command git push'
alias gl='command git pull'
alias gb='command git branch'
alias gco='command git checkout'
alias gsw='command git switch'


# tools
alias art='php artisan'
